{
  "name": "Climb Log",
  "description": "Route logger for climbing sessions",
  "version": "1.0",
  "author": "skyfi",
  "modificationTime": 1773183600,
  "type": "feature",
  "usage": "workout",
  "in": [
    { "name": "Heartrate", "source": "/Activity/Move/-1/Heartrate/Current", "type": "subscribe" }
  ],
  "out": [
    { "name": "routeNum" },
    { "name": "grade" },
    { "name": "routeTime" },
    { "name": "state" },
    { "name": "totalRoutes" },
    { "name": "sessionTime" },
    { "name": "lastGrade" },
    { "name": "lastDuration" },
    { "name": "routeHrAvg" },
    { "name": "totalSends" },
    { "name": "sendPct" },
    { "name": "lastResult" },
    { "name": "climbMode" },
    { "name": "projTries" },
    { "name": "projSends" },
    { "name": "projBest" },
    { "name": "modeSub" }
  ],
  "template": [
    { "name": "setup.html" },
    { "name": "ready.html" },
    { "name": "climb.html" },
    { "name": "break.html" }
  ],
  "settings": [
    {
      "shownName": "Grade System (0-8)",
      "path": "appSettings.gradeSystem",
      "type": "int",
      "min": 0,
      "max": 7,
      "inputType": "slider"
    },
    {
      "shownName": "Difficulty (1-9)",
      "path": "appSettings.defaultGrade",
      "type": "int",
      "min": 1,
      "max": 9,
      "inputType": "slider"
    },
    {
      "shownName": "Project 1 (0=off)",
      "path": "appSettings.proj1",
      "type": "int",
      "min": 0,
      "max": 9,
      "inputType": "slider"
    },
    {
      "shownName": "Project 2 (0=off)",
      "path": "appSettings.proj2",
      "type": "int",
      "min": 0,
      "max": 9,
      "inputType": "slider"
    },
    {
      "shownName": "Project 3 (0=off)",
      "path": "appSettings.proj3",
      "type": "int",
      "min": 0,
      "max": 9,
      "inputType": "slider"
    }
  ]
}
